# Example environment variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Analytics 4 (opcional)
# Obtenha seu ID em: https://analytics.google.com/
VITE_GA_MEASUREMENT_ID=

# Sentry Configuration (opcional)
# Obtenha sua DSN em: https://sentry.io/settings/[org]/projects/[project]/keys/
VITE_SENTRY_DSN=

# Versão da aplicação (preenchido automaticamente)
VITE_APP_VERSION=1.0.0

# =============================================================================
# Stripe (Edge Function secrets — NÃO expor no frontend)
# =============================================================================
# Chave secreta e webhook signing secret. Devem existir apenas nas Edge Functions.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs oficiais (um por plano/período). Preencher com os IDs reais
# criados no Dashboard do Stripe. Formato esperado: price_xxxxxxxxxxxxxxxx.
# Enquanto estiverem vazios, o create-checkout cai em price_data dinâmico
# usando os valores do catálogo (supabase/functions/_shared/stripe-catalog.ts).
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_ANNUAL=

# Chave publicável do Stripe (pode ir para o frontend caso seja usado
# stripe.js diretamente — hoje o app usa apenas Checkout hospedado, então
# permanece opcional).
VITE_STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# URLs & Supabase (Edge Functions)
# =============================================================================
# APP_URL é usada como base para success_url / cancel_url / return_url do Stripe
# em produção. Se ausente, cai para o Origin do request.
APP_URL=

# Injetadas automaticamente pela Lovable Cloud nas Edge Functions.
# Listadas aqui só para documentação — não devem ser preenchidas manualmente.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
